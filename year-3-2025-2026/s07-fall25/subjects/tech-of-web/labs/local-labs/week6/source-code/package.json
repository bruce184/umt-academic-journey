{
  "name": "week6",
  "version": "1.0.0",
  "description": "LAB 6: Express + Handlebars + Knex (Supabase)",
  "private": true,
  "main": "server.js",
  "type": "module",
  "engines": { "node": ">=18.17" },
  "scripts": {
    "dev": "nodemon server.js",
    "dev:debug": "cross-env KNEX_DEBUG=true nodemon server.js",
    "start": "node server.js",
    "start:prod": "cross-env NODE_ENV=production node server.js",
    "db:status": "knex migrate:status",
    "db:migrate": "knex migrate:latest",
    "db:rollback": "knex migrate:rollback",
    "db:seed": "knex seed:run",
    "db:rebuild": "npm run db:rollback -- --all && npm run db:migrate && npm run db:seed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "express-handlebars": "^8.0.3",
    "knex": "^3.1.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.10"
  }
}
