{
  "name": "online-course-management-system",
  "version": "1.0.0",
  "description": "Online Course Management System Frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node ./src/server.js",
    "dev": "nodemon ./src/server.js",
    "test": "cross-env NODE_ENV=test jest --runInBand --detectOpenHandles",
    "format": "prettier -c --write .",
    "lint": "eslint --fix --ext js,jsx,ts,tsx --max-warnings 0 .",
    "lint:report": "eslint --ext js,jsx,ts,tsx --max-warnings 0 ."
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.[jt]s"],
    "verbose": true,
    "globalSetup": "<rootDir>/tests/setup/waitForServer.js"
    ,
    "setupFilesAfterEnv": ["<rootDir>/tests/setup/silenceConsoleWarn.js"]
  },
  "devDependencies": {
    "@eslint/css": "^0.14.1",
    "@eslint/js": "^9.39.1",
    "@eslint/json": "^0.14.0",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.6.2",
    "cross-env": "^7.0.3",
    "jest": "^29.0.0",
    "supertest": "^6.3.3"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.3.34",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-session": "^1.18.2",
    "knex": "^3.1.0",
    "pg": "^8.16.3"
  }
}
