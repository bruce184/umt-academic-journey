<section class="signup-page">
  <div class="site-inner">
    <div class="signup-card">
      <form id="frmSignup" class="needs-validation" novalidate>
        <div class="signup-title">CREATE YOUR ACCOUNT</div>
        <div class="card-body">

        <div class="mb-3">
          <label for="username" class="form-label">Username</label>
          <input id="username" name="username" type="text" class="form-control" placeholder="your_username" required>
          <div class="form-text">
            ≥ 3 ký tự; bắt đầu bằng chữ thường; còn lại a-z, 0-9 hoặc _
          </div>
          <div class="invalid-feedback">
            Username không hợp lệ (vd: <code>abc</code>, <code>huy_123</code>).
          </div>
        </div>

        <div class="mb-3">
          <label for="email" class="form-label">Email address</label>
          <input id="email" name="email" type="email" class="form-control" placeholder="name@example.com" required>
          <div class="invalid-feedback">Email không hợp lệ.</div>
        </div>

        <div class="mb-3">
          <label for="password" class="form-label">Password</label>
          <input id="password" name="password" type="password" class="form-control" required>
          <div class="form-text">
            ≥ 3 ký tự, chỉ gồm a-z, 0-9, dấu <code>_ - .</code>
          </div>
          <div class="invalid-feedback">Password không hợp lệ.</div>
        </div>

        <div class="mb-3">
          <label for="repeat" class="form-label">Repeat password</label>
          <input id="repeat" name="repeat" type="password" class="form-control" required>
          <div class="invalid-feedback">Mật khẩu nhập lại không khớp.</div>
        </div>

      </div>
        <div class="d-flex gap-2 mt-3">
          <button id="btnRegister" class="btn btn-register" type="submit">Register</button>
          <button type="reset" class="btn btn-outline-secondary">Clear</button>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const form = document.getElementById('frmSignup');

  // Regex theo yêu cầu:
  const reUser = /^[a-z][a-z0-9_]{2,}$/;     // >=3; bắt đầu a-z; còn lại a-z0-9_
  const reMail = /^[^@\s]+@[^@\s]+\.[^@\s]+$/; // email đơn giản
  const rePass = /^[a-z0-9_.-]{3,}$/i;        // >=3; chữ số/chữ; _ . -

  const cssOk = (el, ok) => {
    el.classList.remove('is-valid','is-invalid');
    el.classList.add(ok ? 'is-valid' : 'is-invalid');
  };

  form.addEventListener('submit', (e) => {
    e.preventDefault(); // không submit lên server
    const u = form.username, m = form.email, p = form.password, r = form.repeat;

    const vUser = reUser.test(u.value.trim());
    cssOk(u, vUser);

    const vMail = reMail.test(m.value.trim());
    cssOk(m, vMail);

    const vPass = rePass.test(p.value);
    cssOk(p, vPass);

    const vRe = (r.value === p.value) && r.value !== '';
    cssOk(r, vRe);

    const ok = vUser && vMail && vPass && vRe;
    if (ok) {
      // theo yêu cầu bài: chỉ kiểm tra client, không gửi server
      // bạn có thể hiển thị toast/alert nhẹ để báo "Valid"
      alert('Form is valid (client-side).');
    }
  });
});
</script>
