<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Week3"
        tools:targetApi="31">

        <!-- LAUNCHER duy nhất: Activity này sẽ là màn hình chính khi khởi chạy ứng dụng -->
        <activity
            android:name=".example1.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Khai báo các Activity khác của Example 1 -->
        <activity
            android:name=".example1.SecondActivity"
            android:exported="false"
            android:parentActivityName=".example1.MainActivity" />

        <!-- Example 2 -->
        <!-- MainActivity có thể được gọi từ ứng dụng khác, nhưng SecondActivity thì không -->
        <activity
            android:name=".example2.MainActivity"
            android:exported="true" />
        <activity
            android:name=".example2.SecondActivity"
            android:exported="false" /> <!-- Thêm exported="false" để rõ ràng và an toàn -->

        <!-- Example 3 (chạy bằng Specified Activity nên exported=true) -->
        <activity
            android:name=".example3.MainActivity"
            android:exported="true" />

        <!-- Example 4 (chạy bằng Specified Activity nên exported=true) -->
        <activity
            android:name=".example4.MainActivity"
            android:exported="true" />

        <!-- Example 5 (chạy bằng Specified Activity nên exported=true) -->
        <activity
            android:name=".example5.MainActivity"
            android:exported="true" />

    </application>

</manifest>
