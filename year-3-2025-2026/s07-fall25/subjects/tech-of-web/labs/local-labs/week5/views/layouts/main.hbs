<!doctype html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<title>{{title}}</title>
	{{> cssHead}}
	<link rel="stylesheet" href="/styles.css">
</head>
<body>

	<div class="container">
		<div class="row mt-2 mx-1">
			{{> nav}}
		</div>

		<div class="row mt-2 mx-1 gx-0">
			<div class="col-12">
				<div class="card">
					<div class="card-header bg-primary-subtle bg-gradient text-primary-emphasis">
						<h3>{{title}}</h3>
					</div>
					<div class="card-body p-0">
						{{{body}}}
					</div>
				</div>
			</div>
		</div>

		<div class="row mt-2 mx-1">
			{{> footer}}
		</div>
	</div>

	{{> jsBS}}
	<script src="/scripts.js"></script>
</body>
</html>
